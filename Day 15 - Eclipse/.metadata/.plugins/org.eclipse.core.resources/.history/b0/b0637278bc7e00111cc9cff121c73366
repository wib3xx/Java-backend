package com.phonepay.upi;

public class UPI {

	public static void main(String[] args) {
		Account account = new Account(10000, "Sarvagay Sanmotra");
		
		System.out.println("Account Balance: " + account.checkBalance());
		
		account.recieveAmount(1000);
		System.out.println("Amount Recieved: "+"Rs."+ account.checkBalance());
		
		account.transferAmount(2000);
		System.out.println("Amount Transfered: "+ "Rs" + account.checkBalance());
		
	}
	
}
