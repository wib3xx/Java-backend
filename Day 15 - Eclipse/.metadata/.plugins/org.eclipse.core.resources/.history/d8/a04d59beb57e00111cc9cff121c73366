package com.icici.bank;

public class Account {

	private int balance;
	private String name;
	
	public void deposit(int amount) {
		if(amount>0) {
			balance = balance - amount;
		}
	}
	
	public void withdraw(int amount) {
		if(amount <= balance) {
			balance = balance - amount;
		}
	}
	public int checkBalance() {
		return balance;
	}
	
}
