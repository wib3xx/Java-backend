package com.phonepay.upi;

public class Account {

	private int balance;
	private String name;
	
	public void transferAmount(int amount) {
		if(amount <= balance) {
			balance = balance - amount;
		}
	}
	
	public void recieveAmount(int amount) {
		if(amount > 0) {
			balance = balance + amount;
		}
	}
	public int checkBalance() {
		return balance;
	}
	
}
